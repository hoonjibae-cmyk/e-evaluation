# Supabase 프로젝트 URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase Service Role Key 또는 Secret key
# 주의: 이 값은 브라우저에 노출되면 안 됩니다. Vercel 환경변수에만 넣으세요.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# 초기 총괄관리자 생성 코드
# v1.6부터는 관리자 화면 로그인용 비밀번호가 아니라
# 첫 총괄관리자 계정을 만들 때만 사용하는 초기 생성 코드입니다.
ADMIN_ACCESS_CODE=change-this-code

# 선택사항: 관리자 로그인 토큰 서명용 비밀값
# 비워두면 SUPABASE_SERVICE_ROLE_KEY를 기반으로 자동 처리됩니다.
ADMIN_SESSION_SECRET=change-this-long-random-secret
ADMIN_SESSION_HOURS=12

# 선택사항: 배포된 사이트 주소
# 비워두거나 Vercel 환경변수에서 삭제해도 앱이 현재 배포 주소를 자동으로 사용합니다.
# 입력한다면 반드시 실제 배포 주소를 넣으세요. localhost는 배포 환경에서 사용하면 안 됩니다.
# NEXT_PUBLIC_APP_URL=https://YOUR-PROJECT.vercel.app

# v2.2 Slack DM 발송용 Bot User OAuth Token입니다. NEXT_PUBLIC_을 붙이지 마세요.
SLACK_BOT_TOKEN=

# v2.6.0 저장/발송 환경 점검에서 아래 설정을 확인합니다.
# Slack Bot Token에는 chat:write, im:write, users:read.email 권한을 권장합니다.
